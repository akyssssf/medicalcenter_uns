{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    { "source": "/proses/:path*", "destination": "/api/proses/:path*" },
    { "source": "/admin/:path*",  "destination": "/api/admin/:path*" },
    { "source": "/:path*",        "destination": "/api/:path*" }
  ]
}
